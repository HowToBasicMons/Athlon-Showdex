# Showdex imports several @lexical/* submodules directly (e.g. @lexical/rich-text,
# @lexical/link, @lexical/list, @lexical/code, @lexical/markdown). These are transitive
# dependencies of @lexical/react, so pnpm's isolated node_modules doesn't expose them at
# the top level by default. Hoist them so the direct imports resolve.
public-hoist-pattern[]=@lexical/*
